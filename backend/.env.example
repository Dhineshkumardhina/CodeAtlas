# Port for Express Backend Server
PORT=5000

# Server Environment
NODE_ENV=development

# Frontend URL for CORS Configuration
FRONTEND_URL=http://localhost:5173

# MongoDB Connection String URI (local or Atlas)
MONGO_URI=mongodb://localhost:27017/codeatlas

# JWT Token Secret for secure sessions (IMPORTANT: Generate a strong secret for production)
# Generate one with: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345

# Optional: GitHub Personal Access Token (highly recommended to bypass public rate limits)
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Optional: Google Gemini API Key for repo summaries and roadmap analyses
# Create one at: https://aistudio.google.com/
# If left blank, the application launches with a smart offline mock analyser.
GOOGLE_API_KEY=
